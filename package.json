{
  "name": "opengauge",
  "version": "0.2.4",
  "description": "A local-first, token-efficient LLM chat interface",
  "main": "dist/server/index.js",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": ["dist/core/index.d.ts"]
    }
  },
  "bin": {
    "opengauge": "bin/opengauge.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && mkdir -p dist/ui && cp -r src/ui/static dist/ui/static",
    "prepack": "npm run build",
    "start": "node bin/opengauge.js",
    "dev": "tsc --watch"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "keywords": [
    "llm",
    "chat",
    "token-optimization",
    "rag",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "fastify": "^5.2.0",
    "js-yaml": "^4.1.0",
    "onnxruntime-node": "^1.20.0",
    "open": "^10.1.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^7.0.0",
    "tiktoken": "^1.0.18",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
